# Docker Compose environment template
# Copy to docker/.env and customize values before running compose.

# App/API gateway auth
DOC_API_KEYS=dev-key-1
DOC_API_KEY=dev-key-1

# Local model endpoint (for API + Streamlit containers)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional cloud provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Hugging Face cache/offline toggles
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
